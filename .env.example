# 네이버 API (https://developers.naver.com/)
# 용도: 트렌드 상품 발굴 (scripts/trend-discovery.ts)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Claude API (https://console.anthropic.com/)
# 용도: SNS 홍보 문구 자동 생성 (scripts/social-post.ts)
ANTHROPIC_API_KEY=

# Buffer API (https://buffer.com/)
# 용도: SNS 예약 발행 (scripts/social-post.ts)
BUFFER_ACCESS_TOKEN=

# 카카오 비즈메시지 (https://business.kakao.com/)
# 용도: 알림톡 발송 — 주문확인/배송시작/배송완료/마감임박 (scripts/kakao-notification.ts)
KAKAO_REST_API_KEY=
KAKAO_SENDER_KEY=

# 스마트택배 API (https://tracking.sweettracker.co.kr/)
# 용도: 배송 추적 + 상태 변경 알림 (scripts/delivery-tracker.ts)
SWEETTRACKER_API_KEY=
